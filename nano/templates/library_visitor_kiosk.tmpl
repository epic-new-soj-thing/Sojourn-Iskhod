<div class="item">
	<div class="itemLabelWidest">
		<h2>Library Visitor</h2>
	</div>
	<div class="itemContent" style="width: 100%; background-color: #2c2c2c; padding: 8px;">
		{{if data.screenstate === 0}}
			<h2>Search Settings</h2><br>
			{{:helper.link("Filter by Title: " + (data.title || ""), null, {settitle: 1})}}
			{{:helper.link("Filter by Category: " + (data.category || "Any"), null, {setcategory: 1})}}
			{{:helper.link("Filter by Author: " + (data.author || ""), null, {setauthor: 1})}}
			{{:helper.link("Start Search", null, {search: 1})}}
		{{/if}}
		{{if data.screenstate === 1}}
			{{if data.search_error}}
				<span class="bad">ERROR: {{:data.search_error}}</span><br><br>
			{{/if}}
			{{if data.search_results && data.search_results.length}}
				<table>
					<tr><td>AUTHOR</td><td>TITLE</td><td>CATEGORY</td><td>SS<sup>13</sup>BN</td><td></td></tr>
					{{for data.search_results}}
						<tr><td>{{:value.author}}</td><td>{{:value.title}}</td><td>{{:value.category}}</td><td>{{:value.id}}</td><td>{{:helper.link("View", null, {viewbookid: value.id})}}</td></tr>
					{{/for}}
				</table>
				<br>
			{{/if}}
			{{:helper.link("Go Back", null, {back: 1})}}
		{{/if}}
		{{if data.screenstate === 2}}
			<h3>Archive Book</h3>
			{{if data.view_book}}
				<b>{{:data.view_book.title}}</b><br>
				<i>by {{:data.view_book.author || "Unknown"}}</i> (USBN: {{:data.view_book.id}})<br><br>
				<div style="white-space: pre-wrap; background: #eee; padding: 8px; max-height: 400px; overflow-y: auto; color: #333;">{{:data.view_book.content || "(No content)"}}</div><br>
				{{:helper.link("Print and add to library", null, {printbook: 1})}}
			{{else}}
				<span class="bad">No book loaded.</span><br>
			{{/if}}
			{{:helper.link("Back to Search Results", null, {backfromview: 1})}}
		{{/if}}
	</div>
</div>
