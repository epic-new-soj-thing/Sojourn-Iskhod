<div class="item" style="width: 100%; box-sizing: border-box;">
	<div class="itemLabelWidest" style="width: 100%; box-sizing: border-box;">
		<h2 style="margin: 0 0 0.5em 0;">Book Inventory Management</h2>
	</div>
	<div class="itemContent" style="width: 100%; min-height: 320px; box-sizing: border-box; background-color: #2c2c2c; padding: 12px;">
		{{if data.screenstate === 0}}
			<table style="width: 100%; border: 0;">
				<tr><td style="padding: 4px 0; border: 0; vertical-align: top;">{{:helper.link("1. View General Inventory", null, {switchscreen: 1})}}</td></tr>
				<tr><td style="padding: 4px 0; border: 0; vertical-align: top;">{{:helper.link("2. View Checked Out Inventory", null, {switchscreen: 2})}}</td></tr>
				<tr><td style="padding: 4px 0; border: 0; vertical-align: top;">{{:helper.link("3. Check out a Book", null, {switchscreen: 3})}}</td></tr>
				<tr><td style="padding: 4px 0; border: 0; vertical-align: top;">{{:helper.link("4. Connect to External Archive", null, {switchscreen: 4})}}</td></tr>
				<tr><td style="padding: 4px 0; border: 0; vertical-align: top;">{{:helper.link("5. Upload New Title to Archive", null, {switchscreen: 5})}}</td></tr>
				{{if data.emagged}}
					<tr><td style="padding: 4px 0; border: 0; vertical-align: top;">{{:helper.link("6. Access the Forbidden Lore Vault", null, {switchscreen: 6})}}</td></tr>
				{{/if}}
			</table>
			<div style="margin-top: 1em; padding-top: 0.5em; border-top: 1px solid #444; font-size: 92%;">
				<b>Barcode scanner:</b> Use the scanner on this computer to associate.<br>
				Mode 1 = Set book for check-out (then enter recipient on screen 3).<br>
				Mode 2 = Check in (scan book to clear its checkout).<br>
				Mode 3 = Add scanned book to registered inventory.
			</div>
		{{/if}}
		{{if data.screenstate === 1}}
			<div style="width: 100%; box-sizing: border-box; overflow: hidden;">
				<h3 style="margin: 0 0 0.35em 0;">General Inventory (for check-out)</h3>
				<div style="width: 100%; max-height: 400px; overflow-y: auto; overflow-x: hidden; border: 1px solid #444; background: #1a1a1a;">
					<table style="width: 100%; border-collapse: collapse; table-layout: fixed;">
						{{for data.inventory}}
							<tr>
								<td style="padding: 6px 8px; border-bottom: 1px solid #333; word-wrap: break-word; overflow-wrap: break-word;">{{:value.name}}</td>
								<td style="padding: 6px 8px; border-bottom: 1px solid #333; width: 60px; white-space: nowrap;">{{:helper.link("Delete", null, {delbook: value.ref})}}</td>
							</tr>
						{{/for}}
					</table>
				</div>
			</div>
			<div style="margin-top: 0.5em;">{{:helper.link("Return to main menu", null, {switchscreen: 0})}}</div>
		{{/if}}
		{{if data.screenstate === 2}}
			<h3 style="margin: 0 0 0.35em 0;">Checked Out Books</h3>
			<div style="width: 100%; max-height: 280px; overflow-y: auto; overflow-x: hidden; border: 1px solid #444; background: #1a1a1a;">
				<table style="width: 100%; border-collapse: collapse; table-layout: fixed;">
					{{for data.checkouts}}
						<tr>
							<td style="padding: 6px 8px; border-bottom: 1px solid #333; word-wrap: break-word; overflow-wrap: break-word;">
								"{{:value.bookname}}", Checked out to: {{:value.mobname}}<br>
								<span style="font-size: 92%;">Taken: {{:value.timetaken}} min ago, Due: {{if value.overdue}}<span class="bad">{{:value.timedue}}</span>{{else}}{{:value.timedue}}{{/if}}</span><br>
								{{:helper.link("Check In", null, {checkin: value.ref})}}
							</td>
						</tr>
					{{/for}}
				</table>
			</div>
			<div style="margin-top: 0.5em;">{{:helper.link("Return to main menu", null, {switchscreen: 0})}}</div>
		{{/if}}
		{{if data.screenstate === 3}}
			<h3 style="margin: 0 0 0.35em 0;">Check Out a Book</h3>
			<p style="margin: 0 0 0.5em 0;"><i>Scan a book with the barcode scanner (mode 1) to set the book title, or edit below.</i></p>
			<div style="display: block; margin-bottom: 6px;">Book: {{:data.buffer_book || ""}} {{:helper.link("Edit", null, {editbook: 1})}}</div>
			<div style="display: block; margin-bottom: 6px;">Recipient: {{:data.buffer_mob || ""}} {{:helper.link("Edit", null, {editmob: 1})}}</div>
			<div style="display: block; margin-bottom: 6px;">Checkout Date: {{:data.checkout_time}}</div>
			<div style="display: block; margin-bottom: 6px;">Due Date: {{:data.due_time}}</div>
			<div style="display: block; margin-bottom: 8px;">(Checkout Period: {{:data.checkoutperiod}} minutes) {{:helper.link("+", null, {increasetime: 1})}} {{:helper.link("-", null, {decreasetime: 1})}}</div>
			{{:helper.link("Commit Entry", null, {checkout: 1})}}
			<span style="margin-left: 1em;"></span>
			{{:helper.link("Return to main menu", null, {switchscreen: 0})}}
		{{/if}}
		{{if data.screenstate === 4}}
			<h3 style="margin: 0 0 0.35em 0;">External Archive</h3>
			<h4 style="margin: 0.5em 0 0.25em 0;">Printable manuals (in-station)</h4>
			<div style="width: 100%; max-height: 160px; overflow-y: auto; overflow-x: hidden; border: 1px solid #444; background: #1a1a1a; margin-bottom: 0.75em;">
				<table style="width: 100%; border-collapse: collapse; table-layout: fixed;">
					{{for data.printable_manuals}}
						<tr>
							<td style="padding: 4px 8px; border-bottom: 1px solid #333;">{{:value.name}}</td>
							<td style="padding: 4px 8px; border-bottom: 1px solid #333; width: 70px; white-space: nowrap;">{{:helper.link("Print", null, {printmanual: value.index})}}</td>
						</tr>
					{{/for}}
				</table>
			</div>
			<h4 style="margin: 0.5em 0 0.25em 0;">Database archive</h4>
			{{if data.archive_error}}
				<span class="bad">ERROR: {{:data.archive_error}}</span>
			{{else}}
				<div style="margin-bottom: 0.5em;">{{:helper.link("Order book by SS13BN", null, {orderbyid: 1})}}</div>
				<div style="width: 100%; overflow-x: auto; overflow-y: auto; max-height: 220px; border: 1px solid #444;">
					<table style="width: 100%; border-collapse: collapse;">
						<tr>
							<td style="padding: 4px 6px; border: 1px solid #444;">{{:helper.link("AUTHOR", null, {sort: "author"})}}</td>
							<td style="padding: 4px 6px; border: 1px solid #444;">{{:helper.link("TITLE", null, {sort: "title"})}}</td>
							<td style="padding: 4px 6px; border: 1px solid #444;">{{:helper.link("CATEGORY", null, {sort: "category"})}}</td>
							<td style="padding: 4px 6px; border: 1px solid #444;">USBN</td>
							<td style="padding: 4px 6px; border: 1px solid #444;"></td>
						</tr>
						{{for data.archive_results}}
							<tr>
								<td style="padding: 4px 6px; border: 1px solid #444;">{{:value.author}}</td>
								<td style="padding: 4px 6px; border: 1px solid #444;">{{:value.title}}</td>
								<td style="padding: 4px 6px; border: 1px solid #444;">{{:value.category}}</td>
								<td style="padding: 4px 6px; border: 1px solid #444;">{{:value.id}}</td>
								<td style="padding: 4px 6px; border: 1px solid #444;">{{:helper.link("View", null, {viewbookid: value.id})}} {{:helper.link("Order", null, {targetid: value.id})}}</td>
							</tr>
						{{/for}}
					</table>
				</div>
			{{/if}}
			<div style="margin-top: 0.5em;">{{:helper.link("Return to main menu", null, {switchscreen: 0})}}</div>
		{{/if}}
		{{if data.screenstate === 5}}
			<h3 style="margin: 0 0 0.35em 0;">Upload a New Title</h3>
			{{if data.upload_no_scanner}}
				<span class="bad">No scanner found within wireless network range.</span><br>
			{{else data.upload_no_cache}}
				<span class="bad">No data found in scanner memory.</span><br>
			{{else}}
				<div style="margin-bottom: 0.5em;"><span>Data marked for upload...</span></div>
				<div style="display: block; margin-bottom: 4px;"><span>Title: </span>{{:data.upload_scanner_title}}</div>
				<div style="display: block; margin-bottom: 4px;"><span>Author: </span>{{:helper.link(data.upload_scanner_author, null, {setauthor: 1})}}</div>
				<div style="display: block; margin-bottom: 8px;"><span>Category: </span>{{:helper.link(data.upload_category, null, {setcategory: 1})}}</div>
				{{:helper.link("Upload", null, {upload: 1})}}
			{{/if}}
			<div style="margin-top: 0.5em;">{{:helper.link("Return to main menu", null, {switchscreen: 0})}}</div>
		{{/if}}
		{{if data.screenstate === 7}}
			<h3 style="margin: 0 0 0.35em 0;">Archive Book</h3>
			{{if data.view_book}}
				<b>{{:data.view_book.title}}</b><br>
				<i>by {{:data.view_book.author || "Unknown"}}</i> (USBN: {{:data.view_book.id}})<br><br>
				<div style="white-space: pre-wrap; background: #1a1a1a; padding: 10px; max-height: 320px; overflow-y: auto; color: #ccc; border: 1px solid #444; width: 100%; box-sizing: border-box;">{{:data.view_book.content || "(No content)"}}</div><br>
			{{else}}
				<span class="bad">No book loaded.</span><br>
			{{/if}}
			<div style="margin-top: 0.5em;">{{:helper.link("Back to Archive", null, {backfromview: 1})}} &nbsp; {{:helper.link("Return to main menu", null, {switchscreen: 0})}}</div>
		{{/if}}
	</div>
</div>
<div style="width: 100%; margin-top: 0.5em; padding-top: 0.5em; border-top: 1px solid #555; font-size: 90%;"><i>NTOS v2.0.4b Copyright NanoTrasen 2557 - 2561</i></div>
